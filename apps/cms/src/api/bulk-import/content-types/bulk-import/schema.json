{
  "kind": "collectionType",
  "collectionName": "bulk_imports",
  "info": {
    "singularName": "bulk-import",
    "pluralName": "bulk-imports",
    "displayName": "Bulk Import",
    "description": "Upload a CSV to import alumni"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "csvFile": {
      "type": "media",
      "multiple": false,
      "required": true
    },
    "status": {
      "type": "string",
      "default": "pending"
    },
    "report": {
      "type": "text"
    }
  }
}
